{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tfs://generated/continue/agent-schema.json",
  "provider": "continue",
  "agentFile": {
    "paths": [
      ".continue/agents/*.md (project scope)",
      "~/.continue/agents/*.md (user scope)"
    ]
  },
  "frontmatter": {
    "description": {
      "type": "string",
      "required": false,
      "description": "Short description of what this agent does.",
      "jsonSchema": {
        "type": "string"
      }
    },
    "model": {
      "type": "string",
      "required": false,
      "description": "The model id to use for this agent.",
      "jsonSchema": {
        "type": "string"
      }
    },
    "tools": {
      "type": "string (comma-separated native tool names)",
      "required": false,
      "description": "Comma-separated list of native tool names (e.g. 'Read, Edit, Bash').",
      "jsonSchema": {
        "type": "string"
      }
    }
  }
}
