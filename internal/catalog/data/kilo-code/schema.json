{
  "$id": "tfs://generated/kilo-code/agent-schema.json",
  "provider": "kilo-code",
  "agentFile": {
    "paths": [".kilo/agents/<name>.md (project)", "~/.config/kilo/agent/<name>.md (home)"],
    "format": "Markdown with YAML frontmatter",
    "bodyIs": "system prompt"
  },
  "frontmatter": {
    "description": {
      "type": "string",
      "optional": true,
      "jsonSchema": { "type": "string" }
    },
    "model": {
      "type": "string",
      "optional": true,
      "jsonSchema": { "type": "string" }
    },
    "mode": {
      "type": "string",
      "enum": ["primary", "subagent", "all"],
      "optional": true,
      "jsonSchema": { "type": "string" }
    },
    "color": {
      "type": "string",
      "optional": true,
      "jsonSchema": { "type": "string" }
    },
    "steps": {
      "type": "array",
      "optional": true,
      "jsonSchema": { "type": "array" }
    },
    "permission": {
      "type": "object",
      "optional": true,
      "properties": {
        "allow": {"type": "array", "items": {"type": "string"}},
        "deny": {"type": "array", "items": {"type": "string"}},
        "ask": {"type": "array", "items": {"type": "string"}}
      },
      "jsonSchema": {
        "type": "object",
        "properties": {
          "allow": { "type": "array", "items": { "type": "string" } },
          "deny": { "type": "array", "items": { "type": "string" } },
          "ask": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "skillResolution": {
    "supported": true,
    "searchPaths": [".kilo/skills", ".kilocode/skills", ".agents/skills", ".claude/skills", "~/.kilo/skills", "~/.kilocode/skills", "~/.agents/skills"]
  }
}
