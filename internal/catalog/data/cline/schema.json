{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tfs://generated/cline/agent-schema.json",
  "provider": "cline",
  "agentFile": {
    "paths": [
      ".cline/agents/<name>.yaml (project scope)",
      ".cline/agents/<name>.yml (project scope)",
      "~/.cline/agents/<name>.yaml (user scope)",
      "~/.cline/agents/<name>.yml (user scope)"
    ],
    "format": "YAML file with optional YAML frontmatter + Markdown body; body is the agent system prompt.",
    "bodyIs": "system prompt — the Markdown body becomes the agent's instructions delivered to the model."
  },
  "frontmatter": {
    "name": {
      "type": "string",
      "required": true,
      "description": "Display name for the agent.",
      "jsonSchema": {
        "type": "string"
      }
    },
    "description": {
      "type": "string",
      "required": false,
      "description": "Short description shown during agent selection.",
      "jsonSchema": {
        "type": "string"
      }
    },
    "modelId": {
      "type": "string",
      "required": false,
      "description": "The model id to use for this agent (e.g. claude-opus-4-5).",
      "jsonSchema": {
        "type": "string"
      }
    },
    "tools": {
      "type": ["array", "string"],
      "required": false,
      "description": "List of native tool names this agent may use. Accepts a YAML array or comma-separated string.",
      "jsonSchema": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "skills": {
      "type": "array",
      "required": false,
      "description": "List of skill names linked into this agent.",
      "jsonSchema": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  },
  "skillResolution": {
    "supported": true,
    "searchPaths": [
      ".cline/skills",
      ".agents/skills",
      "~/.cline/skills",
      "~/.agents/skills"
    ]
  },
  "sources": [
    {
      "url": "https://docs.cline.bot",
      "type": "official"
    }
  ]
}
