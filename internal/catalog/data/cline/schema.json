{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tfs://generated/cline/agent-schema.json",
  "provider": "cline",
  "agentFile": {
    "paths": [
      ".cline/agents/<name>.yaml (project scope)",
      ".cline/agents/<name>.yml (project scope)",
      "~/.cline/agents/<name>.yaml (user scope)"
    ]
  },
  "frontmatter": {
    "description": {
      "type": "string",
      "required": false,
      "description": "Short description of what this agent does.",
      "jsonSchema": {
        "type": "string"
      }
    },
    "modelId": {
      "type": "string",
      "required": false,
      "description": "The model id to use for this agent (e.g. claude-opus-4-5).",
      "jsonSchema": {
        "type": "string"
      }
    },
    "tools": {
      "type": "YAML list (string[])",
      "required": false,
      "description": "List of native tool names this agent may use.",
      "jsonSchema": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "skills": {
      "type": "YAML list (string[])",
      "required": false,
      "description": "List of skill names linked into this agent.",
      "jsonSchema": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }
}
